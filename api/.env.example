# Copy to .env for local development (this file is committed; .env is git-ignored).

# Postgres connection string. Matches docker-compose.yml.
DATABASE_URL=postgres://pps:pps@localhost:5432/pps_retail

# Secret used to sign login JWTs. Use a long random string in production.
JWT_SECRET=dev-only-change-me

# Port the API listens on. Railway injects PORT automatically in production.
PORT=3000

# Shared secret required (as the x-api-key header) by the /api/sync/* endpoints.
SYNC_API_KEY=dev-sync-key-change-me

# development | production
NODE_ENV=development
