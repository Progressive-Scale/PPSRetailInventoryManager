# Copy to .env for local development (this file is committed; .env is git-ignored).

# --- Database ---
# Owner/superuser connection. Used for migrations and the seed script (DDL +
# cross-tenant writes). On Railway this is the provided DATABASE_URL.
DATABASE_URL=postgres://pps:pps@localhost:5432/pps_retail

# Runtime connection for the API. MUST be a NON-superuser role for Postgres RLS
# to actually take effect (superusers/owners bypass RLS). The enable_rls
# migration creates this "app_user" role for local dev. If unset, the API falls
# back to DATABASE_URL and logs a warning that RLS is not enforced.
APP_DATABASE_URL=postgres://app_user:app_user_dev_pw@localhost:5432/pps_retail

# --- Auth ---
JWT_SECRET=dev-only-change-me

# --- Server ---
# Railway injects PORT in production; do not set it there.
PORT=3000
# development | production
NODE_ENV=development

# Root domain for tenant subdomain resolution.
#   <slug>.ROOT_DOMAIN        -> that company (e.g. demo.yourapp.local)
#   admin.ROOT_DOMAIN         -> platform admin context
# Use yourapp.local in dev (with hosts-file entries), yourapp.com in prod.
ROOT_DOMAIN=yourapp.local
