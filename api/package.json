  "version": "0.1.0",
  "private": true,
  "description": "NestJS + Drizzle REST API for the PPS Retail Inventory Manager.",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
